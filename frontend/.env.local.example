# Backend base URL. The Next.js dev server proxies /api and /files to this host
# (see next.config.ts rewrites) so cookies/tokens work on the same origin.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# WebSocket URL. Same host as the backend. In production, put behind TLS (wss://).
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
